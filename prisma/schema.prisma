// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Dev: sqlite (file:./db/custom.db) — set in .env
  // Prod (Vercel): postgresql — set DATABASE_URL in Vercel env vars
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH.js (NextAuth v5) models — required by @auth/prisma-adapter
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  // OvinFormulation custom fields
  role          String    @default("STUDENT") // STUDENT | FARMER | FEED_MILL | COOPERATIVE | ADMIN
  preferredLang String    @default("fr") // fr | en | ar
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  // Classroom submissions
  studentSubmissions Submission[] @relation("UserSubmissions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// SUBSCRIPTION & BILLING (Stripe)
// ============================================================

model Subscription {
  id                     String              @id @default(cuid())
  userId                 String              @unique
  status                 String              @default("FREE") // FREE | TRIALING | ACTIVE | PAST_DUE | CANCELED | INCOMPLETE
  tier                   String              @default("STUDENT") // STUDENT | FARMER | FEED_MILL | COOPERATIVE
  // Stripe customer + subscription IDs
  stripeCustomerId       String?             @unique
  stripeSubscriptionId   String?             @unique
  stripePriceId          String?
  // Billing period
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean             @default(false)
  // Metadata
  trialEndsAt            DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices               Invoice[]

  @@index([stripeCustomerId])
  @@index([status])
}

model Invoice {
  id                  String   @id @default(cuid())
  subscriptionId      String
  stripeInvoiceId     String   @unique
  amountDue           Int      // cents
  amountPaid          Int      // cents
  currency            String   @default("eur")
  status              String   // draft | open | paid | uncollectible | void
  invoicePdf          String?  // URL
  hostedInvoiceUrl    String?
  createdAt           DateTime @default(now())

  subscription        Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
}

// ============================================================
// Legacy models (kept for backward compat with existing code)
// ============================================================

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Classroom Mode (Academy LMS) ----------

model Assignment {
  id          String   @id @default(cuid())
  code        String   @unique // 6-char code for students to join
  title       String
  description String
  animalCategory String // target animal
  // Constraints
  maxCostPerDay    Float?  // €/animal/day max
  minPDICoverage   Float   // % PDI coverage minimum (e.g. 95)
  minUFLCoverage   Float   // % UFL coverage minimum
  minPabsCoverage  Float?  // % Pabs coverage minimum
  minCaabsCoverage Float?  // % Caabs coverage minimum
  maxConcentratePct Float? // max % of concentrate in MS
  // Grading weights (must sum to 100)
  weightCost       Float   // weight of cost in grade
  weightCoverage   Float   // weight of nutritional coverage
  weightFeasibility Float  // weight of UEM feasibility
  // Metadata
  createdBy        String  // teacher name
  createdAt        DateTime @default(now())
  dueDate          DateTime?
  isActive         Boolean  @default(true)
  // LMS fields
  difficulty       String  @default("normal") // easy, normal, hard, expert
  topic            String  @default("general") // gestation, lactation, croissance, engrais, general
  templateId       String? // if created from a template

  submissions Submission[]

  @@index([createdBy])
}

model Submission {
  id          String   @id @default(cuid())
  assignmentId String
  studentName String
  studentEmail String?
  // Link to authenticated user (optional — students may submit anonymously)
  userId      String?
  // Ration data (JSON)
  rationData  String   // JSON string of the ration (feeds, quantities, etc.)
  // Computed metrics
  totalUFL    Float
  totalPDI    Float
  totalPabs   Float
  totalCaabs  Float
  totalMS     Float
  totalCost   Float
  coverageUFL Float  // %
  coveragePDI Float  // %
  coveragePabs Float // %
  coverageCaabs Float // %
  concentratePct Float // %
  feasibleUM  Boolean
  // Grading
  score       Float?  // 0-100
  grade       String? // A, B, C, D, F
  feedback    String? // auto-generated feedback
  submittedAt DateTime @default(now())

  assignment  Assignment @relation(fields: [assignmentId], references: [id])
  user        User?      @relation("UserSubmissions", fields: [userId], references: [id])

  @@index([assignmentId])
  @@index([studentName])
  @@index([userId])
}

// ---------- Academy LMS Extensions ----------

model Student {
  id          String   @id @default(cuid())
  name        String
  email       String?
  // Aggregated stats
  totalSubmissions Int   @default(0)
  averageScore     Float @default(0)
  bestScore        Float @default(0)
  certificatesEarned Int @default(0)
  // Skill mastery (0-100 per skill)
  skillEnergy       Float @default(0) // UFL coverage
  skillProtein      Float @default(0) // PDI coverage
  skillMinerals     Float @default(0) // Pabs/Caabs coverage
  skillCost         Float @default(0) // cost optimization
  skillFeasibility  Float @default(0) // UEM feasibility
  // Timestamps
  firstSubmission DateTime?
  lastSubmission  DateTime?
  createdAt       DateTime @default(now())

  @@index([name])
}

model Template {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // gestation, lactation, croissance, engrais, general
  difficulty  String   @default("normal") // easy, normal, hard, expert
  animalCategory String
  maxCostPerDay    Float?
  minPDICoverage   Float   @default(95)
  minUFLCoverage   Float   @default(95)
  minPabsCoverage  Float?
  minCaabsCoverage Float?
  maxConcentratePct Float?
  weightCost       Float   @default(40)
  weightCoverage   Float   @default(40)
  weightFeasibility Float  @default(20)
  estimatedTime    Int     @default(20) // minutes
  learningObjectives String // JSON array of objectives
  isOfficial      Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model Certificate {
  id          String   @id @default(cuid())
  studentName String
  assignmentId String?
  assignmentTitle String
  score       Float
  grade       String
  issuedAt    DateTime @default(now())
  certificateNumber String @unique

  @@index([studentName])
}

// ---------- Feed Mill: Production & Traceability ----------

model ProductionBatch {
  id            String   @id @default(cuid())
  batchNumber   String   @unique
  formulaName   String
  formulaSnapshot String
  targetQuantityKg Float
  actualQuantityKg Float?
  status        String   @default("planned")
  productionLine String  @default("Line A")
  startDate     DateTime?
  endDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())

  lots          Lot[]

  @@index([status])
  @@index([productionLine])
}

model Lot {
  id            String   @id @default(cuid())
  lotNumber     String   @unique
  type          String
  feedName      String
  quantityKg    Float
  supplier      String?
  receivedDate  DateTime?
  qualityStatus String   @default("pending")
  coaUrl        String?
  notes         String?
  createdAt     DateTime @default(now())

  batchId       String?
  batch         ProductionBatch? @relation(fields: [batchId], references: [id])
  ingredientLots LotGenealogy[] @relation("IngredientLot")
  batchLots      LotGenealogy[] @relation("BatchLot")
  shipments      ShipmentLot[]

  @@index([type])
  @@index([qualityStatus])
}

model LotGenealogy {
  id            String   @id @default(cuid())
  ingredientLotId String
  batchLotId    String
  quantityUsedKg Float
  createdAt     DateTime @default(now())

  ingredientLot Lot @relation("IngredientLot", fields: [ingredientLotId], references: [id])
  batchLot      Lot @relation("BatchLot", fields: [batchLotId], references: [id])

  @@index([ingredientLotId])
  @@index([batchLotId])
}

model SalesOrder {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  customerName  String
  customerPhone String?
  customerAddress String?
  product       String
  quantityKg    Float
  unitPrice     Float
  totalAmount   Float
  status        String   @default("pending")
  orderDate     DateTime @default(now())
  deliveryDate  DateTime?
  notes         String?

  shipments     Shipment[]

  @@index([status])
  @@index([customerName])
}

model Shipment {
  id            String   @id @default(cuid())
  shipmentNumber String  @unique
  orderId       String
  shipmentDate  DateTime @default(now())
  quantityKg    Float
  status        String   @default("pending")
  driver        String?
  vehicle       String?
  notes         String?

  order         SalesOrder @relation(fields: [orderId], references: [id])
  lots          ShipmentLot[]

  @@index([orderId])
  @@index([status])
}

model ShipmentLot {
  id            String   @id @default(cuid())
  shipmentId    String
  lotId         String
  quantityKg    Float

  shipment      Shipment @relation(fields: [shipmentId], references: [id])
  lot           Lot @relation(fields: [lotId], references: [id])

  @@index([shipmentId])
  @@index([lotId])
}
